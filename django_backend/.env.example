# Paystack
# Get from: https://dashboard.paystack.com/settings/developer
PAYSTACK_PUBLIC_KEY=pk_test_your_actual_key_here
PAYSTACK_SECRET_KEY=sk_test_your_actual_key_here

# Tingg/Cellulant
# Get from: Your Tingg dashboard
TINGG_SECRET_KEY=your_actual_secret_key_here
TINGG_PUBLIC_KEY=your_actual_public_key_here
TINGG_WEBHOOK_SECRET=your_webhook_secret_here

# Lemonsqueezy
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_actual_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id_here

# PawaPay (African Mobile Money)
# Get from: Your PawaPay merchant dashboard
PAWAPAY_API_KEY=your_actual_pawapay_jwt_token_here
PAWAPAY_API_URL=https://api.pawapay.cloud
PAWAPAY_WEBHOOK_SECRET=your_pawapay_webhook_secret_here

# OpenAI Configuration (for AI Chatbot)
