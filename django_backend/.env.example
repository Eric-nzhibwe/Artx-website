# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.onrender.com

# ─── Database (PostgreSQL on Render) ──────────────────────────────────────────
# Go to Render Dashboard → New → PostgreSQL → copy the Internal Database URL
DATABASE_URL=postgresql://user:password@host/dbname

# ─── Superuser (auto-created on first deploy via build.sh) ────────────────────
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=choose-a-strong-password

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,https://your-app-name.onrender.com

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_MODE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=ARTX Platform <noreply@artx.com>

# ─── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ─── PawaPay (African Mobile Money) ───────────────────────────────────────────
# https://dashboard.pawapay.cloud → API Keys
PAWAPAY_API_KEY=your_pawapay_jwt_here
PAWAPAY_API_URL=https://api.pawapay.cloud
PAWAPAY_WEBHOOK_SECRET=your_pawapay_webhook_secret_here

# ─── Paystack ──────────────────────────────────────────────────────────────────
# https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_your_key_here

# ─── OpenAI (AI Chatbot) ───────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
# ⚠️ NEVER commit your real key — keep it in .env only
OPENAI_API_KEY=sk-proj-your_key_here
