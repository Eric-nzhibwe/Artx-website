{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd django_backend && pip install -r requirements.txt && bash build.sh"
  },
  "deploy": {
    "startCommand": "cd django_backend && daphne -p $PORT -b 0.0.0.0 --proxy-headers artx_platform.asgi:application",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}